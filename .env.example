# AlphaLens AI — Environment Variables
# Copy this file to .env.local and fill in your keys

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for: News Agent (sentiment analysis), Reasoning Agent, Decision Agent, Explainability Agent
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the model used by LLM agents (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o
